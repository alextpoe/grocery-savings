{
  "permissions": {
    "allow": [
      "Bash(pnpm lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm test*)",
      "Bash(pnpm verify*)",
      "Bash(pnpm build*)",
      "Bash(pnpm format*)",
      "Bash(pnpm db:generate*)",
      "Bash(pnpm install)",
      "Bash(pnpm exec prettier*)",
      "Bash(pnpm exec tsc*)",
      "Bash(turbo run*)",
      "Bash(supabase status*)",
      "Bash(supabase migration list*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(supabase db push*)",
      "Bash(supabase projects*)",
      "Bash(supabase secrets*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(apps/**/.env)",
      "Read(apps/**/.env.local)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/format.mjs\""
          }
        ]
      }
    ]
  }
}
