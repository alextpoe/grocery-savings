{
  "name": "@grocery-savings/api",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./queries": "./src/queries/index.ts",
    "./mutations": "./src/mutations/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "generate": "supabase gen types typescript --local > src/types/database.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "@tanstack/react-query": "^5.24.1"
  },
  "devDependencies": {
    "@grocery-savings/config": "workspace:*",
    "@types/react": "^18.2.57",
    "react": "^18.2.0",
    "supabase": "^1.142.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  },
  "peerDependencies": {
    "react": "^18.2.0"
  }
}
