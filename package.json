{
  "name": "grocery-savings",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@grocery-savings/web",
    "dev:mobile": "turbo dev --filter=@grocery-savings/mobile",
    "build": "turbo build",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "verify": "turbo lint typecheck test",
    "verify:db": "node scripts/smoke.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @grocery-savings/api generate",
    "db:reset": "supabase db reset",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@grocery-savings/config": "workspace:*",
    "@supabase/supabase-js": "^2.39.7",
    "husky": "^9.1.0",
    "prettier": "^3.2.5",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
